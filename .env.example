# Argent stores local data outside the repository by default.
# Override these only if you know where you want local private state to live.
ARGENT_HOME=
ARGENT_DB_PATH=
ARGENT_EXPORT_DIR=
ARGENT_RULES_PATH=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_CLIENT_NAME=Argent
PLAID_CLIENT_USER_ID=local-user
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=
PLAID_VERSION=2020-09-14
