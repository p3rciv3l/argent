{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@argent/core": ["packages/core/src/index.ts"],
      "@argent/core/*": ["packages/core/src/*"],
      "@argent/connectors": ["packages/connectors/src/index.ts"],
      "@argent/connectors/*": ["packages/connectors/src/*"],
      "@argent/plaid": ["packages/plaid/src/index.ts"],
      "@argent/plaid/*": ["packages/plaid/src/*"],
      "@argent/mcp": ["apps/mcp/src/index.ts"],
      "@argent/mcp/*": ["apps/mcp/src/*"]
    }
  }
}
